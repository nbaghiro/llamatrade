{
  "name": "@llamatrade/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LlamaTrade \"Monolith\" design system — Tailwind preset, shared CSS layer, and presentational React components. Ships source (no build step); consumed directly by Vite apps.",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./themes/monolith.css": "./src/themes/monolith.css",
    "./tailwind-preset": "./tailwind-preset.cjs"
  },
  "files": [
    "src",
    "tailwind-preset.cjs"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
