{
  "name": "@llamatrade/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LlamaTrade shared brain — platform-neutral Connect clients, Zustand stores, generated proto, and design tokens. Ships source (no build step); consumed by apps/web and apps/mobile.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./net": "./src/net/index.ts",
    "./theme": "./src/theme/tokens.ts",
    "./format": "./src/format.ts",
    "./stores": "./src/stores/index.ts",
    "./stores/*": "./src/stores/*.ts",
    "./proto/*": "./src/proto/*.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "proto": "cd ../../libs/proto && buf generate --template buf.gen.core.yaml",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
