# Frontend Environment Variables

# Direct service URLs for Connect protocol (no proxy needed)
VITE_AUTH_URL=http://localhost:8810
VITE_STRATEGY_URL=http://localhost:8820
VITE_BACKTEST_URL=http://localhost:8830
VITE_MARKET_DATA_URL=http://localhost:8840
VITE_TRADING_URL=http://localhost:8850
VITE_PORTFOLIO_URL=http://localhost:8860
VITE_NOTIFICATION_URL=http://localhost:8870
VITE_BILLING_URL=http://localhost:8880

# WebSocket URL for real-time updates (still via gateway for now)
VITE_WS_URL=ws://localhost:8840/ws

# Stripe publishable key (required for billing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Frontend runs on port 8800 (configurable via vite.config.ts)
