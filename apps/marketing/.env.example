# Marketing site environment variables (all optional; build-time, VITE_-prefixed)

# Loops (https://loops.so) newsletter-form id for the beta waitlist.
# Create a Form in Loops, copy its id, and set it here. When unset, the waitlist
# form falls back to a placeholder and stays inert (validates but does not POST).
# Alternatively, hard-code the id directly in src/components/WaitlistForm.tsx.
VITE_LOOPS_FORM_ID=
