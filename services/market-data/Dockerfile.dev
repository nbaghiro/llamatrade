# LlamaTrade Market Data Service - Development Dockerfile

FROM python:3.14-slim

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy shared libraries first
COPY libs/common /app/libs/common
COPY libs/db /app/libs/db
COPY libs/proto /app/libs/proto
COPY libs/alpaca /app/libs/alpaca

# Install shared libraries (editable for hot-reload)
RUN pip install --no-cache-dir -e /app/libs/common -e /app/libs/db -e /app/libs/proto -e /app/libs/alpaca

# Copy service dependencies
COPY services/market-data/pyproject.toml services/market-data/README.md ./

# Install service dev dependencies
RUN pip install --no-cache-dir -e ".[dev]"

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8004

EXPOSE 8004

CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8004", "--reload", "--reload-dir", "/app/src"]
