# Run all services locally with hot-reload
# Usage: honcho start -f Procfile.dev
# Install: pip install honcho

auth: cd services/auth && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47810 --reload --reload-dir src
strategy: cd services/strategy && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47820 --reload --reload-dir src
backtest: cd services/backtest && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47830 --reload --reload-dir src
market-data: cd services/market-data && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47840 --reload --reload-dir src
trading: cd services/trading && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47850 --reload --reload-dir src
portfolio: cd services/portfolio && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47860 --reload --reload-dir src
notification: cd services/notification && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47870 --reload --reload-dir src
billing: cd services/billing && source .venv/bin/activate && uvicorn src.main:app --host 0.0.0.0 --port 47880 --reload --reload-dir src
web: cd apps/web && npm run dev -- --host 0.0.0.0 --port 47300
