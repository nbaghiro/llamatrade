# LlamaTrade Environment Variables

# Alpaca API (Paper Trading)
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret

# JWT Secret (generate a strong random string for production)
JWT_SECRET=dev-secret-change-in-production

# Encryption Key (generate a strong random string for production)
ENCRYPTION_KEY=dev-encryption-key-change-me

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:47532/llamatrade

# Redis
REDIS_URL=redis://localhost:47379

# Stripe (optional - for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@llamatrade.com

# GCP (for deployment)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# ===================
# Local Development Ports (all prefixed with LT_ to avoid conflicts)
# ===================
# All ports use the 47xxx range to avoid conflicts with common services
# Override these if needed
LT_POSTGRES_PORT=47532
LT_REDIS_PORT=47379
LT_WEB_PORT=47333
LT_GATEWAY_PORT=47800
LT_GATEWAY_ADMIN_PORT=47801
LT_AUTH_PORT=47810
LT_STRATEGY_PORT=47820
LT_BACKTEST_PORT=47830
LT_MARKET_DATA_PORT=47840
LT_TRADING_PORT=47850
LT_PORTFOLIO_PORT=47860
LT_NOTIFICATION_PORT=47870
LT_BILLING_PORT=47880
