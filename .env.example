# LlamaTrade Environment Variables

# Alpaca API (Paper Trading)
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret

# JWT Secret (generate a strong random string for production)
JWT_SECRET=dev-secret-change-in-production

# Encryption Key (generate a strong random string for production)
ENCRYPTION_KEY=dev-encryption-key-change-me

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llamatrade

# Redis
REDIS_URL=redis://localhost:6379

# Stripe (optional - for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@llamatrade.com

# GCP (for deployment)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# ===================
# gRPC Configuration
# ===================
# Enable/disable gRPC for all services (set to false to use HTTP only)
USE_GRPC=true

# Enable gRPC for specific inter-service calls
USE_GRPC_MARKET_DATA=true

# gRPC service targets (for inter-service communication)
MARKET_DATA_GRPC_TARGET=market-data:8840
AUTH_GRPC_TARGET=auth:8810
TRADING_GRPC_TARGET=trading:8850
BACKTEST_GRPC_TARGET=backtest:8830

# ===================
# Portfolio Ledger (rollout flags — default off)
# ===================
# Phase 1: ingest fills + reconcile against broker truth, read-only (drives nothing).
LEDGER_SHADOW_MODE=false
# Phase 2: sleeve lifecycle + fund disbursement APIs (deposit/allocate/transfer).
LEDGER_SLEEVES=false
# Phase 3: sleeve-aware sizing/execution is authoritative.
LEDGER_EXECUTION=false
# Phase 4: declarative desired-state reconciliation loop.
LEDGER_DESIRED_STATE=false
# Phase 5: block-and-allocate netting / internal crosses.
LEDGER_NETTING=false
# Shadow reconciliation cadence (seconds).
LEDGER_RECONCILE_INTERVAL_SECONDS=300
