# LlamaTrade Environment Variables

# Alpaca API (Paper Trading)
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret

# JWT Secret (generate a strong random string for production)
JWT_SECRET=dev-secret-change-in-production

# Encryption Key (generate a strong random string for production)
ENCRYPTION_KEY=dev-encryption-key-change-me

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llamatrade

# Redis
REDIS_URL=redis://localhost:6379

# Stripe (optional - for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@llamatrade.com

# Agent / LLM (AI copilot service - required for agent to make LLM calls)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
# AGENT_LLM_MODEL=claude-sonnet-4-20250514

# GCP (for deployment)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# ===================
# gRPC Configuration
# ===================
# Enable/disable gRPC for all services (set to false to use HTTP only)
USE_GRPC=true

# Enable gRPC for specific inter-service calls
USE_GRPC_MARKET_DATA=true

# gRPC service targets (for inter-service communication)
MARKET_DATA_GRPC_TARGET=market-data:8840
AUTH_GRPC_TARGET=auth:8810
TRADING_GRPC_TARGET=trading:8850
BACKTEST_GRPC_TARGET=backtest:8830

# ===================
# Portfolio Ledger (the book of record — always on; no feature flags)
# ===================
# Reconciliation cadence: how often the ledger aggregate is checked against
# broker truth (seconds).
LEDGER_RECONCILE_INTERVAL_SECONDS=300
# Equity-curve snapshot cadence: how often accounts/sleeves are marked to market
# into the read-side time series (seconds).
LEDGER_SNAPSHOT_INTERVAL_SECONDS=3600

# === Market-Data Store (dedicated TimescaleDB) ===
# The market-data service ingests Alpaca bars into a dedicated Timescale instance
# and serves the platform from it (Alpaca is fallback only).
MARKET_DATA_DB_URL=postgresql+asyncpg://postgres:postgres@timescaledb:5432/market_data
MARKET_DATA_FEED=iex                      # iex (free) or sip (paid, full universe)
MARKET_DATA_UNIVERSE=AAPL,MSFT,SPY        # comma-separated symbols to sync
MARKET_DATA_MINUTE_LOOKBACK_DAYS=5        # recent minute-bar window to backfill
MARKET_DATA_DAILY_LOOKBACK_DAYS=365       # daily history to backfill
MARKET_DATA_BARS_FROM_BUS=true            # serving sources live bars from the bus
